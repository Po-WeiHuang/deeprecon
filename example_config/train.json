{
  "model": {
    "class_path": "model.hitsrecon.SNOPosEnegyRecon",
    "init_args": {
      "num_heads": 4,
      "num_layers": 2,
      "n_pmts": 9728,
      "d_model": 64,
      "ff_dim": 128,
      "dropout": 0.2
    }
  },
  "train": {
    "seed": 801,
    "project": "TrainRecon",
    "name": "OnelayDec_TwoLayerEnc_FitValidPerData",
    "entity": "po-wei-huang-university-of-oxford",
    "tags": "March",
    "wandbcachepath": "/data/snoplus2/weiiiii/uv/deeprecon/wandb_logs",
    "checkpoint_dir": "/data/snoplus2/weiiiii/uv/deeprecon/results/train1/ckpt",
    "device": "cuda",
    "metric_monitor": {
      "class_path": "metrics.metric_monitor.PositionEnergyMonitor"
