            "cache": true
          }
        },
        "batch_size": 512,
        "num_workers": 16,
        "shuffle": false,
        "pin_memory": true
      }
    },
    "val_dataloader": {
      "class_path": "torch.utils.data.DataLoader",
      "collate_fn_name": "collate_varlen",
      "init_args": {
        "dataset": {
          "class_path": "utils.datasets.PosEnergyRecoDataset",
          "init_args": {
            "file_paths": "/data/snoplus2/weiiiii/electron_bismsb_0dot5_10/ValNtuple/ValPerfect/*.ntuple.root",
            "tree_name": "output",
            "truth_expressions": ["mcPosx", "mcPosy", "mcPosz", "mcPosr", "mcEdepQuenched", "mctime1"],
